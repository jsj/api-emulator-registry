{
  "name": "@api-emulator/cloudflare",
  "version": "0.1.0",
  "description": "Cloudflare API emulator plugin for api-emulator",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "prepack": "bun run build"
  },
  "keywords": [
    "api-emulator",
    "cloudflare",
    "workers",
    "d1",
    "kv",
    "r2"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5.7"
  },
  "peerDependencies": {
    "api-emulator": ">=0.7.0"
  }
}
