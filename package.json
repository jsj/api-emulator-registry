{
  "name": "api-emulator-plugins",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "provider-wall": "node scripts/update-provider-wall.mjs",
    "check:provider-wall": "node scripts/update-provider-wall.mjs --check",
    "provider-readmes": "node scripts/generate-provider-readmes.mjs",
    "check:provider-readmes": "node scripts/generate-provider-readmes.mjs --check",
    "publish:providers": "node scripts/publish-provider-packages.mjs",
    "check:conformance": "node scripts/check-conformance.mjs",
    "conformance:report": "node scripts/conformance-report.mjs",
    "conformance:drift": "node scripts/conformance-drift.mjs",
    "contract:cloudflare": "node scripts/check-cloudflare-openapi-coverage.mjs",
    "contract:github": "node scripts/check-github-openapi-coverage.mjs",
    "contract:google-workspace": "node scripts/check-google-workspace-coverage.mjs",
    "contract:plaid": "node scripts/check-plaid-openapi-coverage.mjs",
    "smoke": "node scripts/smoke-all.mjs",
    "smoke:cli": "bun scripts/cli-verification-smoke.mjs",
    "smoke:db-workspaces": "node @supabase/smoke-db-workspace.mjs && node @neon/smoke-db-workspace.mjs && node @planetscale/smoke-db-workspace.mjs && node @supabase/smoke-postgres-thin-clone.mjs",
    "supabase:pg:clone": "node @supabase/local-postgres/workspace.mjs clone",
    "supabase:pg:dispose": "node @supabase/local-postgres/workspace.mjs dispose",
    "supabase:dev": "node @supabase/dev.mjs",
    "supabase:pg": "node @supabase/local-postgres/branch.mjs start",
    "supabase:pg:reset": "node @supabase/local-postgres/branch.mjs reset",
    "planetscale:mysql": "node @planetscale/local-mysql/branch.mjs start",
    "planetscale:mysql:reset": "node @planetscale/local-mysql/branch.mjs reset"
  }
}
